# DeepSeek API (or compatible OpenAI-style API)
DEEPSEEK_API_KEY=sk-your-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Database (default: SQLite, change to PostgreSQL in production)
DATABASE_URL=sqlite+aiosqlite:///./data/lexicon.db

# CORS — comma-separated origins allowed to access the API
CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:8088

# Admin
ADMIN_TOKEN=change-me
JWT_SECRET=change-me-too
